# Browser/public URLs
FRONTEND_BASE_URL=https://stg.plane.samsungds.net
ALLOWED_REDIRECT_HOSTS=stg.plane.samsungds.net

# Corporate ADFS/OIDC
OIDC_CLIENT_ID=
OIDC_ISSUER=
ADFS_AUTH_URL=
ADFS_LOGOUT_URL=
OIDC_REDIRECT_URI=https://stg.plane.samsungds.net/auth/google/callback/
ADFS_CER_PATH=/app/login_certs/stsds.secsso.net.cer

# Session cookie. form_post callbacks require SameSite=None and HTTPS.
SESSION_COOKIE_NAME=l0_spider_sessionid
SESSION_COOKIE_AGE=86400
SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=None

# Keep enabled in production. Set to 0 only for isolated compatibility diagnostics.
OIDC_VERIFY_TOKEN=1
OIDC_CLOCK_TOLERANCE_SECONDS=60
